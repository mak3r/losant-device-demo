# Copy this file to .env and fill in values.
# NEVER commit .env to git — it is gitignored.
#
# Usage:
#   cp .env.template .env
#   # edit .env with your values
#   source .env

# AWS credentials (alternative: use ~/.aws/credentials or IAM instance profile)
export AWS_ACCESS_KEY_ID=your_access_key_here
export AWS_SECRET_ACCESS_KEY=your_secret_key_here
export AWS_DEFAULT_REGION=us-east-1

# Losant API token — required for ldc-demo create
# Generate at: https://app.losant.com/ → Settings → API Tokens
export LDC_LOSANT_API_TOKEN=your_losant_api_token_here

# Losant Application ID — required for ldc-demo create
# Found in your Losant application URL: app.losant.com/applications/<id>
export LDC_LOSANT_APPLICATION_ID=your_application_id_here

# SSH public key path (default: ~/.ssh/id_rsa.pub)
# export LDC_SSH_PUBLIC_KEY=~/.ssh/id_rsa.pub

# SSH private key path for kubeconfig fetch (default: ~/.ssh/id_rsa)
# export LDC_SSH_PRIVATE_KEY=~/.ssh/id_rsa
